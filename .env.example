# Hathor services
FULLNODE_URL=http://127.0.0.1:8080
WALLET_HEADLESS_URL=http://localhost:8000

# Blueprint IDs (published on-chain)
BLUEPRINT_ID=
CHANNEL_BLUEPRINT_ID=

# Wallet IDs (must exist in wallet-headless)
BUYER_WALLET_ID=buyer
FACILITATOR_WALLET_ID=facilitator
SELLER_WALLET_ID=seller

# Wallet addresses
BUYER_ADDRESS=
FACILITATOR_ADDRESS=
SELLER_ADDRESS=

# Custom token UID (optional — leave empty for HTR-only)
# The server will accept both HTR and this token if set
CUSTOM_TOKEN_UID=

# Ports
FACILITATOR_PORT=8402
RESOURCE_SERVER_PORT=3000

# Escrow settings
ESCROW_DEADLINE_SECONDS=300

# Payment amounts (in smallest unit — 1 HTR = 100)
HTR_PAYMENT_AMOUNT=100
CUSTOM_TOKEN_PAYMENT_AMOUNT=1000
